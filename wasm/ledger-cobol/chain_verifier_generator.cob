    display "import edu.singaporetech.inf2007quiz01.data.local"
        ".BlockEntity"
    display "import java.security.MessageDigest"
    display " "
    display "/**"
    display " * Blockchain integrity verifier for CalBot."
    display " *"
    display " * THIS FILE IS GENERATED BY COBOL."
    display " * Do not edit manually."
    display " *"
    display " * Generated by: chain_verifier_generator.cob"
    display " * Compiler: GCC gcobol 15.2.1"
    display " * Language: COBOL-85"
    display " *"
    display " * The verification logic herein was specified in"
    display " * COBOL PROCEDURE DIVISION paragraphs and emitted"
    display " * as Kotlin source code.  The COBOL source is the"
    display " * canonical enterprise specification; this Kotlin"
    display " * is the portable runtime implementation."
    display " *"
    display " * Verification rules (from COBOL specification):"
    display " *   1. Genesis anchor: first block prevHash must"
