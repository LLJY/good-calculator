>>SOURCE FORMAT IS FREE

*> Standalone test for the COBOL ledger formatter.
*> Compile: gcobol test_standalone.cob -o test_standalone
*> Run:     ./test_standalone

identification division.
program-id. test-standalone.

data division.
working-storage section.
01 ws-calbot-id              pic 9(4)   value 7.
01 ws-expression             pic x(50)  value "3+5".
01 ws-result                 pic s9(10) sign leading value +8.
01 ws-block-hash             pic x(64)  value
    "ab12cd34ef56789000000000000000000000000000000000000000000000dead".
01 ws-timestamp              pic 9(18)  value 1742299200000000.
01 ws-raft-term              pic 9(4)   value 1.
01 ws-leader-node            pic 9(1)   value 2.

01 ws-calbot-id-edit         pic 9(4).
01 ws-expression-edit        pic x(50).
01 ws-result-edit            pic -(9)9.
01 ws-raft-term-edit         pic 9(4).
01 ws-leader-node-edit       pic 9(1).
01 ws-hash-preview           pic x(8).
01 ws-formatted              pic x(256).

procedure division.
    display "=== COBOL LEDGER FORMATTER TEST ===".
    display "Running on GCC gcobol " with no advancing.
    display "15.2.1".
    display " ".

    move ws-calbot-id to ws-calbot-id-edit
    move function trim(ws-expression trailing)
        to ws-expression-edit
    move ws-result to ws-result-edit
    move ws-raft-term to ws-raft-term-edit
    move ws-leader-node to ws-leader-node-edit
    move ws-block-hash(1:8) to ws-hash-preview

    move spaces to ws-formatted
    string
        "CALBOT-" delimited by size
        ws-calbot-id-edit delimited by size
        " | " delimited by size
        function trim(ws-expression-edit trailing)
            delimited by size
        " = " delimited by size
        function trim(ws-result-edit trailing)
            delimited by size
        " | TERM:" delimited by size
        ws-raft-term-edit delimited by size
        " | NODE:" delimited by size
        ws-leader-node-edit delimited by size
        " | HASH:" delimited by size
        ws-hash-preview delimited by size
        "..." delimited by size
        into ws-formatted
    end-string

    display "Formatted ledger line:".
    display ws-formatted.
    display " ".
    display "This output was generated by a COBOL program".
    display "compiled via GCC gcobol, running on Linux,".
    display "as part of an Android calculator blockchain.".
    display " ".
    display "Language count in this project: 11".

    stop run.
