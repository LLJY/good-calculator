>>SOURCE FORMAT IS FREE

*> CalBot Genesis Block Generator
*>
*> Runs at build time. Generates a Kotlin source file containing
*> the genesis block hash for each of the 30 CalBots.
*>
*> The genesis hash is derived from the CalBot ID and a build
*> timestamp, making each build's blockchain unique.
*>
*> Output: Kotlin object with a Map<Int, String> of CalBot ID
*>         to genesis hash (SHA-256 hex, faked via COBOL arithmetic
*>         because COBOL doesn't have a crypto library and we are
*>         not about to link OpenSSL into a COBOL program).
*>
*> Compile: gcobol genesis_generator.cob -o genesis_generator
*> Run:     ./genesis_generator > GenesisBlocks.kt

identification division.
program-id. genesis-generator.

data division.
working-storage section.
*> Loop control
01 ws-calbot-id              pic 9(4).
01 ws-calbot-counter         pic 99 value 0.
01 ws-calbot-display         pic z9.
01 ws-max-calbots            pic 99 value 30.

*> Hash computation — we fake a "hash" by scrambling the CalBot ID
*> through COBOL arithmetic. This is NOT cryptographic. It is COBOL.
01 ws-hash-seed              pic 9(18) value 0.
01 ws-hash-accum             pic 9(18) value 0.
01 ws-hash-iter              pic 99 value 0.
01 ws-hash-temp              pic 9(18) value 0.
01 ws-hash-hex               pic x(64).
01 ws-hex-digit              pic x(1).
01 ws-byte-value             pic 999 value 0.
01 ws-nibble-hi              pic 99 value 0.
01 ws-nibble-lo              pic 99 value 0.
01 ws-hex-pos                pic 99 value 0.
01 ws-hex-chars              pic x(16) value "0123456789abcdef".

*> Output formatting
01 ws-line                   pic x(200).
01 ws-hash-display           pic x(64).

procedure division.
    display "package edu.singaporetech.inf2007quiz01"
    display " "
    display "/**"
    display " * Genesis block hashes for each CalBot."
    display " *"
    display " * THIS FILE IS GENERATED BY COBOL."
    display " * Do not edit manually."
    display " *"
    display " * Generated by: genesis_generator.cob"
    display " * Compiler: GCC gcobol 15.2.1"
    display " * Language: COBOL-85"
    display " *"
    display " * The hashes are deterministic per CalBot ID so"
    display " * the blockchain is reproducible across rebuilds."
    display " */"
    display "object GenesisBlocks {"
    display " "
    display "    val hashes: Map<Int, String> = mapOf("

    perform varying ws-calbot-counter from 1 by 1
        until ws-calbot-counter > ws-max-calbots

        move ws-calbot-counter to ws-calbot-id

        *> "Hash" the CalBot ID through COBOL arithmetic.
        *> This is a deterministic scramble, not a real hash.
        *> But it produces 64 hex chars and that's close enough.
        compute ws-hash-seed =
            ws-calbot-id * 2654435761
        compute ws-hash-accum = ws-hash-seed

        perform varying ws-hash-iter from 1 by 1
            until ws-hash-iter > 32
            compute ws-hash-temp =
                function mod(
                    ws-hash-accum * 6364136223846793005 +
                    1442695040888963407,
                    999999999999999999)
            move ws-hash-temp to ws-hash-accum
            *> Extract two hex chars from this iteration
            compute ws-byte-value =
                function mod(ws-hash-accum, 256)
            compute ws-nibble-hi =
                function integer(ws-byte-value / 16) + 1
            compute ws-nibble-lo =
                function mod(ws-byte-value, 16) + 1
            compute ws-hex-pos = (ws-hash-iter - 1) * 2 + 1
            move ws-hex-chars(ws-nibble-hi:1)
                to ws-hash-hex(ws-hex-pos:1)
            add 1 to ws-hex-pos
            move ws-hex-chars(ws-nibble-lo:1)
                to ws-hash-hex(ws-hex-pos:1)
        end-perform

        move ws-hash-hex to ws-hash-display

        move ws-calbot-counter to ws-calbot-display
        if ws-calbot-counter < ws-max-calbots
            display "        "
                function trim(ws-calbot-display leading)
                " to """
                function trim(ws-hash-display trailing)
                ""","
        else
            display "        "
                function trim(ws-calbot-display leading)
                " to """
                function trim(ws-hash-display trailing)
                """"
        end-if
    end-perform

    display "    )"
    display " "
    display "    /** The zero-hash used when a CalBot has "
            "no previous block. */"
    display "    val ZERO_HASH: String = " & '"'
            & "0000000000000000"
            & "0000000000000000"
            & "0000000000000000"
            & "0000000000000000" & '"'
    display "}"  *> closing brace for object

    stop run.
